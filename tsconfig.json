{
    "compilerOptions": {
        "paths": {
            "*": ["./client/src/*"],
            "modules/crm/*": ["./client/modules/crm/src/*"],
            "crm:*": ["./client/modules/crm/src/*"]
        },
        "module": "ES6",
        "target": "ES2018",
        "lib": [
            "ES2019",
            "Decorators"
        ],
        "moduleResolution": "bundler",
        "skipLibCheck": true,
        "allowJs": true,
        "checkJs": false,
        "noEmit": true,
        "strictPropertyInitialization": false
    },
    "include": [
        "client/src",
        "client/modules/crm/src"
    ]
}
